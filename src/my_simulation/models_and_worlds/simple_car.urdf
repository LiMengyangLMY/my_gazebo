<?xml version="1.0" ?>
<robot name="simple_car">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/> 
      <geometry><box size="0.5 0.5 0.07"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry><box size="0.5 0.5 0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.10 0.02"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision><geometry><box size="0.02 0.10 0.02"/></geometry></collision>
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>

  <link name="left_camera_optical_frame"/>
  <link name="right_camera_optical_frame"/>

  <link name="left_front_wheel">
    <visual><geometry><cylinder length="0.03" radius="0.03"/></geometry><material name="black"/></visual>
    <collision><geometry><cylinder length="0.03" radius="0.03"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>
  <link name="right_front_wheel"><visual><geometry><cylinder length="0.03" radius="0.03"/></geometry><material name="black"/></visual><collision><geometry><cylinder length="0.03" radius="0.03"/></geometry></collision><inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="left_rear_wheel"><visual><geometry><cylinder length="0.03" radius="0.03"/></geometry><material name="black"/></visual><collision><geometry><cylinder length="0.03" radius="0.03"/></geometry></collision><inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="right_rear_wheel"><visual><geometry><cylinder length="0.03" radius="0.03"/></geometry><material name="black"/></visual><collision><geometry><cylinder length="0.03" radius="0.03"/></geometry></collision><inertial><mass value="0.1"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>

  <link name="left_front_guard">
    <visual>
      <geometry><box size="0.55 0.018 0.03"/></geometry>
      <material name="guard_black"><color rgba="0.10 0.10 0.10 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="0.55 0.018 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0008"/>
    </inertial>
  </link>

  <link name="right_front_guard">
    <visual>
      <geometry><box size="0.55 0.018 0.03"/></geometry>
      <material name="guard_black"/>
    </visual>
    <collision>
      <geometry><box size="0.55 0.018 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.0008" ixy="0" ixz="0" iyy="0.0008" iyz="0" izz="0.0008"/>
    </inertial>
  </link>

  <link name="left_guard_tip">
    <visual>
      <geometry><cylinder length="0.05" radius="0.04"/></geometry>
      <material name="guard_black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <link name="right_guard_tip">
    <visual>
      <geometry><cylinder length="0.05" radius="0.04"/></geometry>
      <material name="guard_black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.10"/>
      <inertia ixx="0.0004" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0004"/>
    </inertial>
  </link>

  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_front_wheel"/>
    <axis xyz="0 0 1"/><origin xyz="0.18 0.27 0" rpy="-1.5708 0 0"/> 
  </joint>
  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_front_wheel"/>
    <axis xyz="0 0 1"/><origin xyz="0.18 -0.27 0" rpy="-1.5708 0 0"/>
  </joint>
  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="left_rear_wheel"/>
    <axis xyz="0 0 1"/><origin xyz="-0.18 0.27 0" rpy="-1.5708 0 0"/>
  </joint>
  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="base_link"/><child link="right_rear_wheel"/>
    <axis xyz="0 0 1"/><origin xyz="-0.18 -0.27 0" rpy="-1.5708 0 0"/>
  </joint>

  <joint name="base_to_left_front_guard" type="fixed">
    <parent link="base_link"/>
    <child link="left_front_guard"/>
    <origin xyz="0.40 0.24 -0.005" rpy="0 0 0.60"/>
  </joint>

  <joint name="base_to_right_front_guard" type="fixed">
    <parent link="base_link"/>
    <child link="right_front_guard"/>
    <origin xyz="0.40 -0.24 -0.005" rpy="0 0 -0.60"/>
  </joint>

  <joint name="left_front_guard_to_tip" type="fixed">
    <parent link="left_front_guard"/>
    <child link="left_guard_tip"/>
    <origin xyz="0.305 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="right_front_guard_to_tip" type="fixed">
    <parent link="right_front_guard"/>
    <child link="right_guard_tip"/>
    <origin xyz="0.305 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="base_to_camera" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.25 0 0.055" rpy="0 0 0"/>
  </joint>
  
  <joint name="camera_to_left_optical" type="fixed">
    <parent link="camera_link"/><child link="left_camera_optical_frame"/>
    <origin xyz="0 0.03 0" rpy="0 0 0"/>
  </joint>
  <joint name="camera_to_right_optical" type="fixed">
    <parent link="camera_link"/><child link="right_camera_optical_frame"/>
    <origin xyz="0 -0.03 0" rpy="0 0 0"/>
  </joint>

  <gazebo>
    <plugin name="skid_steer_drive_controller" filename="libgazebo_ros_skid_steer_drive.so">
      <alwaysOn>true</alwaysOn>
      <updateRate>20</updateRate>
      <leftFrontJoint>left_front_wheel_joint</leftFrontJoint>
      <rightFrontJoint>right_front_wheel_joint</rightFrontJoint>
      <leftRearJoint>left_rear_wheel_joint</leftRearJoint>
      <rightRearJoint>right_rear_wheel_joint</rightRearJoint>
      <wheelSeparation>0.54</wheelSeparation>
      <wheelDiameter>0.06</wheelDiameter>
      <torque>10</torque>
      <commandTopic>/cmd_vel</commandTopic>
      <odometryTopic>/odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
    </plugin>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor type="multicamera" name="stereo_camera">
      <update_rate>30.0</update_rate>
      <camera name="left">
        <pose>0 0.03 0 0 0 0</pose>
        <horizontal_fov>1.5707963</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.02</near><far>300</far></clip>
      </camera>
      <camera name="right">
        <pose>0 -0.03 0 0 0 0</pose>
        <horizontal_fov>1.5707963</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.02</near><far>300</far></clip>
      </camera>
      <plugin name="stereo_camera_controller" filename="libgazebo_ros_multicamera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <cameraName>stereo_camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>left_camera_optical_frame</frameName>
        <hackBaseline>0.06</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

</robot>
