<launch>
  <arg name="paused" default="false"/>
  <arg name="wait_for_manual_start" default="false"/>
  <arg name="startup_delay_sec" default="0.0"/>
  <arg name="artifacts_output_dir" default=""/>
  <arg name="strategy" default="segment"/>
  <arg name="scene_file" default="$(find my_simulation)/config/scenes/demo_4.yaml"/>

  <!-- 1. 加载 URDF 机器人模型 -->
  <param name="robot_description" command="cat /home/lmy/catkin_ws/src/my_simulation/models_and_worlds/simple_car.urdf"/>

  <!-- 2. 启动 Gazebo 并加载 World -->
  <include file="/opt/ros/noetic/share/gazebo_ros/launch/empty_world.launch">
    <arg name="world_name" value="/home/lmy/catkin_ws/src/my_simulation/models_and_worlds/tennis_court.world"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
  </include>

  <!-- 3. 在 Gazebo 中生成机器人 -->
  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model" output="screen"
        args="-param robot_description -urdf -model simple_car -x 0.8 -y 0 -z 0.05"/>

  <node name="ball_scene_spawner" pkg="my_simulation" type="ball_scene_spawner.py" output="screen">
    <rosparam command="load" file="$(arg scene_file)"/>
    <param name="ball_radius" value="0.033"/>
  </node>

  <!-- 4. 第二阶段最小闭环控制节点 -->
  <node name="stereo_node" pkg="my_simulation" type="stereo_node" output="screen">
    <param name="config_path" value="/home/lmy/catkin_ws/src/my_simulation/config/stereo_config.yaml"/>
    <param name="model_path" value="/home/lmy/catkin_ws/src/my_simulation/weights/best.onnx"/>
    <param name="left_topic" value="/stereo_camera/left/image_raw"/>
    <param name="right_topic" value="/stereo_camera/right/image_raw"/>
    <param name="output_frame" value="camera_link"/>
    <param name="sync_tolerance_sec" value="0.10"/>
  </node>

  <!-- 5. 第二阶段最小闭环控制节点 -->
  <node name="ball_pickup_controller" pkg="my_simulation" type="ball_pickup_controller" output="screen">
    <rosparam command="load" file="$(arg scene_file)"/>
    <param name="robot_model_name" value="simple_car"/>
    <param name="strategy" value="$(arg strategy)"/>
    <param name="control_frequency" value="12.0"/>
    <param name="max_linear_speed" value="0.4"/>
    <param name="max_angular_speed" value="0.8"/>
    <param name="front_boundary_x" value="0.6917"/>
    <param name="pickup_half_width" value="0.25"/>
    <param name="pickup_tolerance" value="0.02"/>
    <param name="x_error_margin" value="0.0241"/>
    <param name="depth_error_margin" value="0.0356"/>
    <param name="segment_pickup_side_shrink" value="0.0356"/>
    <param name="segment_guidance_inset" value="0.0356"/>
    <param name="shared_advance_lateral_overflow_tolerance" value="0.04"/>
    <param name="shared_advance_heading_tolerance" value="0.14"/>
    <param name="shared_realign_lateral_overflow_tolerance" value="0.10"/>
    <param name="shared_realign_heading_tolerance" value="0.28"/>
    <param name="shared_realign_forward_error_threshold" value="0.20"/>
    <param name="shared_advance_heading_deadband" value="0.06"/>
    <param name="shared_advance_lateral_deadband" value="0.02"/>
    <param name="shared_advance_min_linear_speed" value="0.08"/>
    <param name="shared_advance_min_angular_speed" value="0.05"/>
    <param name="shared_advance_max_angular_speed" value="0.18"/>
    <param name="shared_rotate_min_angular_speed" value="0.10"/>
    <param name="enable_recovery" value="false"/>
    <param name="visual_target_match_distance" value="1.50"/>
    <param name="visual_positions_timeout" value="1.00"/>
    <param name="visual_position_ema_alpha" value="0.20"/>
    <param name="point_pick_heading_tolerance" value="0.14"/>
    <param name="point_pick_lateral_tolerance" value="0.07"/>
    <param name="point_realign_heading_tolerance" value="0.40"/>
    <param name="point_realign_lateral_tolerance" value="0.22"/>
    <param name="advance_heading_deadband" value="0.12"/>
    <param name="point_advance_lateral_deadband" value="0.08"/>
    <param name="point_advance_max_angular_speed" value="0.12"/>
    <param name="control_mode_hold_sec" value="0.15"/>
    <param name="control_mode_switch_confirm_cycles" value="6"/>
    <param name="linear_cmd_slew_rate" value="0.55"/>
    <param name="angular_cmd_slew_rate" value="0.90"/>
    <param name="startup_delay_sec" value="$(arg startup_delay_sec)"/>
    <param name="wait_for_manual_start" value="$(arg wait_for_manual_start)"/>
    <param name="artifacts_output_dir" value="$(arg artifacts_output_dir)"/>
  </node>
</launch>
